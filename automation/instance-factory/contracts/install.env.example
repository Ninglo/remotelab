# Desired modes
REMOTELAB_MODE=on
INGRESS_CLOUDFLARE_MODE=on
INGRESS_CPOLAR_MODE=off
CONNECTOR_EMAIL_MODE=auto
WORKER_MAILBOX_MODE=auto
CONNECTOR_FEISHU_MODE=auto
CONNECTOR_CALENDAR_MODE=auto

# Cloudflare ingress
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_NAME=thelab

# Optional cpolar
CPOLAR_AUTH_TOKEN=

# Email connector / mailbox worker
AGENT_MAILBOX_ADDRESS=
AGENT_MAIL_HTTP_BRIDGE_SECRET=
AGENT_MAIL_PUBLIC_BASE_URL=

# Feishu connector
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Calendar connector
CALENDAR_PROVIDER=google
CALENDAR_GOOGLE_CREDENTIALS_FILE=
CALENDAR_GOOGLE_TOKEN_FILE=
