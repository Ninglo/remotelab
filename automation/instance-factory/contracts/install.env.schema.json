{
  "schemaVersion": 1,
  "title": "RemoteLab install.env contract",
  "modes": ["on", "off", "auto"],
  "keys": {
    "REMOTELAB_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["remotelab"],
      "default": "on"
    },
    "INGRESS_CLOUDFLARE_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["ingress.cloudflare"],
      "default": "auto"
    },
    "INGRESS_CPOLAR_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["ingress.cpolar"],
      "default": "off"
    },
    "CONNECTOR_EMAIL_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["connector.email"],
      "default": "auto"
    },
    "WORKER_MAILBOX_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["worker.mailbox"],
      "default": "auto"
    },
    "CONNECTOR_FEISHU_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["connector.feishu"],
      "default": "auto"
    },
    "CONNECTOR_CALENDAR_MODE": {
      "kind": "desired_mode",
      "requiredFor": ["connector.calendar"],
      "default": "auto"
    },
    "CLOUDFLARE_API_TOKEN": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["ingress.cloudflare"]
    },
    "CLOUDFLARE_ACCOUNT_ID": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["ingress.cloudflare"]
    },
    "CLOUDFLARE_TUNNEL_ID": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["ingress.cloudflare"]
    },
    "CLOUDFLARE_TUNNEL_NAME": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["ingress.cloudflare"]
    },
    "CPOLAR_AUTH_TOKEN": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["ingress.cpolar"]
    },
    "AGENT_MAILBOX_ADDRESS": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["connector.email", "worker.mailbox"]
    },
    "AGENT_MAIL_HTTP_BRIDGE_SECRET": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["connector.email"]
    },
    "AGENT_MAIL_PUBLIC_BASE_URL": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["connector.email"]
    },
    "FEISHU_APP_ID": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["connector.feishu"]
    },
    "FEISHU_APP_SECRET": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["connector.feishu"]
    },
    "FEISHU_VERIFICATION_TOKEN": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["connector.feishu"]
    },
    "FEISHU_ENCRYPT_KEY": {
      "kind": "capability_input",
      "secret": true,
      "usedBy": ["connector.feishu"]
    },
    "CALENDAR_PROVIDER": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["connector.calendar"]
    },
    "CALENDAR_GOOGLE_CREDENTIALS_FILE": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["connector.calendar"]
    },
    "CALENDAR_GOOGLE_TOKEN_FILE": {
      "kind": "capability_input",
      "secret": false,
      "usedBy": ["connector.calendar"]
    }
  }
}
