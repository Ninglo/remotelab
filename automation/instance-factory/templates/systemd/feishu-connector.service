[Unit]
Description=RemoteLab Feishu connector
After=network-online.target remotelab.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory={{repoCheckoutPath}}
EnvironmentFile=/etc/remotelab/install-profile.env
ExecStart=/usr/bin/env node {{repoCheckoutPath}}/scripts/feishu-connector.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
