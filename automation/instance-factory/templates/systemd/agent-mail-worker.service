[Unit]
Description=RemoteLab embedded mailbox worker
After=network-online.target remotelab.service remotelab-agent-mail-http-bridge.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory={{repoCheckoutPath}}
EnvironmentFile=/etc/remotelab/install-profile.env
ExecStart=/usr/bin/env node {{repoCheckoutPath}}/scripts/agent-mail-worker.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
